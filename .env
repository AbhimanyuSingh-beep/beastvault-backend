PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database - Updated for Docker connectivity
DB_HOST=postgres
DB_PORT=5432
DB_NAME=beastvault
DB_USER=postgres
DB_PASSWORD=beastpass123

JWT_SECRET=super_secret_beast_mode_key_999

# Redis - Updated for Docker connectivity
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO - Updated for Docker connectivity
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET_NAME=beastvault-videos
S3_PUBLIC_URL=http://localhost:9000/beastvault-videos

MAX_UPLOAD_SIZE_MB=500
TRANSCODE_RESOLUTIONS=360,720

# Your confirmed Windows FFMPEG paths
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe